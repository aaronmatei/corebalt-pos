@inherits LayoutComponentBase
@inject IServiceScopeFactory ScopeFactory

<div class="layout">
    <AuthorizeView>
        <Authorized>
            <aside class="sidebar">
                <div class="brand">
                    <img src="/favicon.ico" class="logo" alt="Corebalt" />
                    <span>Corebalt</span>
                </div>
                <nav>
                    <NavLink href="/products" Match="NavLinkMatch.Prefix">Products</NavLink>
                    <NavLink href="/categories">Categories</NavLink>
                    <NavLink href="/stock">Stock</NavLink>
                    <NavLink href="/reorder">
                        Reorder
                        @if (_lowStockCount > 0)
                        {
                            <span class="badge" title="@_lowStockCount items need reordering">@_lowStockCount</span>
                        }
                    </NavLink>
                    <NavLink href="/users">Cashiers</NavLink>
                    <NavLink href="/sessions">Sessions</NavLink>
                    <NavLink href="/day-summary">Day summary</NavLink>
                    <NavLink href="/backups">Backups</NavLink>
                    <NavLink href="/settings">Settings</NavLink>
                </nav>
                <form method="post" action="/backoffice/logout" class="logout">
                    <Csrf />
                    <button type="submit">Sign out (@context.User.Identity?.Name)</button>
                </form>
            </aside>
        </Authorized>
    </AuthorizeView>
    <main class="content">
        @Body
    </main>
</div>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }
    private int _lowStockCount;

    protected override async Task OnInitializedAsync()
    {
        // The badge is only meaningful for an authenticated manager; never let it break login/setup pages.
        if (AuthState is null) return;
        var state = await AuthState;
        if (state.User.Identity?.IsAuthenticated != true) return;

        // Query in an ISOLATED DI scope so the badge gets its own DbContext — sharing the request-scoped
        // one with the page being rendered races it ("a second operation started on this context").
        // ICurrentContext flows from the (singleton) HttpContextAccessor, so the scope still sees the claims.
        try
        {
            using var scope = ScopeFactory.CreateScope();
            var lowStock = scope.ServiceProvider.GetRequiredService<Pos.Application.Inventory.LowStockService>();
            _lowStockCount = await lowStock.CountAsync();
        }
        catch { _lowStockCount = 0; }
    }
}
