@page "/hq/catalog"
@attribute [Authorize(Policy = "BackOfficeManager")]
@inject Pos.Application.Catalog.CatalogItemService Catalog

<h1>Catalogue</h1>
<p style="color:var(--muted)">The central catalogue. Changes here are pushed to every branch and apply at the tills on their next sync.</p>

@if (!string.IsNullOrEmpty(Error)) { <p class="error">@Error</p> }

<form method="post" action="/backoffice/catalog" class="card" style="margin-bottom:14px; display:flex; gap:8px; flex-wrap:wrap; align-items:end">
    <Csrf />
    <label>SKU<br /><input name="sku" required /></label>
    <label>Name<br /><input name="name" required /></label>
    <label>Price<br /><input name="priceAmount" type="number" step="0.01" min="0" required style="width:90px" /></label>
    <label>Unit<br /><select name="unit">@foreach (var u in Enum.GetNames<Pos.Domain.Catalog.UnitOfMeasure>()) { <option>@u</option> }</select></label>
    <label>Tax<br /><select name="taxClass">@foreach (var t in Enum.GetNames<Pos.Domain.Catalog.TaxClass>()) { <option>@t</option> }</select></label>
    <label>Barcode<br /><input name="barcode" /></label>
    <button type="submit">Add item</button>
</form>

@if (_items is not null)
{
    <table>
        <thead><tr><th>SKU</th><th>Name</th><th>Unit</th><th>Tax</th><th style="text-align:right">Price</th><th>Status</th><th></th></tr></thead>
        <tbody>
            @foreach (var i in _items)
            {
                <tr style="@(i.IsActive ? "" : "opacity:.55")">
                    <td>@i.Sku</td>
                    <td>@i.Name</td>
                    <td>@i.UnitOfMeasure</td>
                    <td>@i.TaxClass</td>
                    <td style="text-align:right">
                        <form method="post" action="/backoffice/catalog/@i.Id/price" style="display:inline-flex; gap:4px">
                            <Csrf />
                            <input name="priceAmount" type="number" step="0.01" min="0" value="@Money(i.Price.Amount)" style="width:80px" />
                            <button type="submit" title="Reprice">@i.Price.Currency ↵</button>
                        </form>
                    </td>
                    <td>@(i.IsActive ? "Active" : "Inactive")</td>
                    <td>
                        <form method="post" action="/backoffice/catalog/@i.Id/active" style="display:inline">
                            <Csrf />
                            <input type="hidden" name="active" value="@((!i.IsActive).ToString().ToLowerInvariant())" />
                            <button type="submit">@(i.IsActive ? "Deactivate" : "Reactivate")</button>
                        </form>
                    </td>
                </tr>
            }
            @if (_items.Count == 0) { <tr><td colspan="7" style="color:var(--muted)">No catalogue items yet.</td></tr> }
        </tbody>
    </table>
}

@code {
    [SupplyParameterFromQuery] public string? Error { get; set; }
    private IReadOnlyList<Pos.Domain.Catalog.CatalogItem>? _items;

    protected override async Task OnInitializedAsync() => _items = await Catalog.ListAsync(includeInactive: true);

    private static string Money(decimal d) => d.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture);
}
