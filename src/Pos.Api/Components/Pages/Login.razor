@page "/login"
@layout EmptyLayout
@inject Pos.Application.Abstractions.ICurrentTenant Tenant

<div class="login-card">
    <h1>@(string.IsNullOrWhiteSpace(Tenant.DisplayName) ? "Corebalt POS" : Tenant.DisplayName)</h1>
    <p>@(string.IsNullOrWhiteSpace(Tenant.DisplayName) ? "Back office sign in" : "Back office sign in · powered by Corebalt POS")</p>
    <form method="post" action="/backoffice/login">
        <Csrf />
        <label>Username</label>
        <input name="username" autocomplete="username" autofocus />
        <label>Password</label>
        <input name="password" type="password" autocomplete="current-password" />
        <button type="submit">Sign in</button>
    </form>
    @if (!string.IsNullOrEmpty(Error))
    {
        <p class="error" style="margin-top:14px">@Error</p>
    }
</div>

@code {
    [SupplyParameterFromQuery] public string? Error { get; set; }
}
