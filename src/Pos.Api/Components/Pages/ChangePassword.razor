@page "/change-password"
@layout EmptyLayout
@attribute [Authorize(Policy = "BackOfficeManager")]

<div class="login-card">
    <h1>Change password</h1>
    <p>Set a new password to continue.</p>
    <form method="post" action="/backoffice/change-password">
        <Csrf />
        <label>Current password</label>
        <input name="currentPassword" type="password" autocomplete="current-password" />
        <label>New password</label>
        <input name="newPassword" type="password" autocomplete="new-password" />
        <button type="submit">Update password</button>
    </form>
    @if (!string.IsNullOrEmpty(Error))
    {
        <p class="error" style="margin-top:14px">@Error</p>
    }
</div>

@code {
    [SupplyParameterFromQuery] public string? Error { get; set; }
}
