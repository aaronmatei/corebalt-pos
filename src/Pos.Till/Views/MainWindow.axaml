<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Pos.Till.ViewModels"
        xmlns:views="using:Pos.Till.Views"
        x:Class="Pos.Till.Views.MainWindow"
        x:DataType="vm:ShellViewModel"
        Width="1100" Height="720"
        MinWidth="900" MinHeight="600"
        Icon="/Assets/corebalt-icon.ico"
        Title="Corebalt POS Till">

  <ContentControl Content="{Binding Current}">
    <ContentControl.DataTemplates>
      <DataTemplate DataType="vm:LoginViewModel">
        <views:LoginView/>
      </DataTemplate>
      <DataTemplate DataType="vm:MainViewModel">
        <views:TillView/>
      </DataTemplate>
    </ContentControl.DataTemplates>
  </ContentControl>
</Window>
