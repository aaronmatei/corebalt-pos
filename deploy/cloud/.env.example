# Copy to `.env` (gitignored) and fill in. Used by docker-compose.cloud.yml.

# The base host under which tenant subdomains live. Tenants become {slug}.pos.corebalt.co.ke.
TENANT_BASE_DOMAIN=pos.corebalt.co.ke

# Postgres password for the shared cloud DB (generate a long random one).
POSTGRES_PASSWORD=

# HMAC signing key for JWTs (>= 32 chars). Generate: openssl rand -base64 48
JWT_KEY=

# Platform-admin token for tenant onboarding (POST /admin/tenants, header X-Admin-Token).
# Generate: openssl rand -hex 32
ADMIN_API_TOKEN=

# Cloudflare API token scoped to Zone:DNS:Edit for corebalt.co.ke (for the ACME DNS-01 wildcard cert).
CLOUDFLARE_API_TOKEN=

# Email for Let's Encrypt registration / expiry notices.
ACME_EMAIL=ops@corebalt.co.ke
