bin/
obj/
*.user
.vs/
.vscode/
.idea/
.claude/

# Install-level config holds per-client secrets (DB password, signing key) — never commit the filled file.
appsettings.Production.json
appsettings.*.Local.json

# Cloud deploy secrets (Cloudflare token, DB password, JWT/admin keys) — only .env.example is committed.
.env
deploy/cloud/.env

# Publish output + runtime per-install folders.
dist/
logs/
backups/
dp-keys/
schema-version.json

# Installer build inputs (downloaded portable Postgres + MSVC runtime) — fetched, not committed.
deploy/installer/pgsql/
deploy/installer/redist/
